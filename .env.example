# Discord
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id

# AI — Google AI Studio (Gemma)
GEMINI_API_KEY=your_google_ai_studio_key
GEMMA_MODEL=gemma-3-27b-it
AI_TEMPERATURE=0.2
AI_TOP_P=0.9
AI_TOP_K=40
AI_MAX_OUTPUT_TOKENS=512

# AI — OpenAI (primary)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5-nano
OPENAI_REASONING_EFFORT=minimal
OPENAI_VERBOSITY=low

# Server
PORT=3001

# Optional
ADMIN_USER_ID=
GLOBAL_COOLDOWN_MS=5000
MAX_CONVERSATION_HISTORY=15
MAX_TOOL_ROUNDS=10

# Security (optional)
SECURITY_AUTO_KICK_BOTS=true
SECURITY_AUTO_BAN_BOTS=false
SECURITY_TRUSTED_BOT_IDS=
SECURITY_SNAPSHOT_INTERVAL_MS=300000
SECURITY_SNAPSHOT_RETENTION=3
SECURITY_ALERT_COOLDOWN_MS=300000
SECURITY_AUDIT_LOG_WINDOW_MS=45000
SECURITY_EVENT_WINDOW_MS=60000
SECURITY_RAID_JOIN_WINDOW_MS=120000
SECURITY_RAID_JOIN_THRESHOLD=6
SECURITY_CHANNEL_DELETE_THRESHOLD=3
SECURITY_CHANNEL_CREATE_THRESHOLD=6
SECURITY_CHANNEL_RENAME_THRESHOLD=5
SECURITY_ROLE_DELETE_THRESHOLD=3
SECURITY_ROLE_CREATE_THRESHOLD=4
SECURITY_ROLE_RENAME_THRESHOLD=5
SECURITY_ROLE_PERM_CHANGE_THRESHOLD=3
SECURITY_EMOJI_DELETE_THRESHOLD=5
SECURITY_EMOJI_CREATE_THRESHOLD=8
SECURITY_EMOJI_RENAME_THRESHOLD=5
SECURITY_BAN_THRESHOLD=3
SECURITY_RESTORE_RULES_CHANNEL=true
SECURITY_RESTORE_ANNOUNCEMENTS_CHANNEL=true
SECURITY_RULES_CHANNEL_NAME=rules
SECURITY_ANNOUNCEMENTS_CHANNEL_NAME=announcements
SECURITY_RULES_MESSAGE=This channel is reserved for server rules. Contact the admins if you need access.
SECURITY_ANNOUNCEMENTS_MESSAGE=Important announcements will be posted here.
SECURITY_SET_SYSTEM_CHANNEL_TO_ANNOUNCEMENTS=true
